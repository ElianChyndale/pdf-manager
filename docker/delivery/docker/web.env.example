# Docker 公共版前端运行时配置
# 复制此文件为 web.env 并填入你的密钥
FRONT_API_BASE=

# 后端鉴权 key（必须和 auth.local.json 中的某个 key 一致）
FRONT_X_API_KEY=change-me-to-your-backend-api-key

# 前端默认 OCR provider
FRONT_OCR_PROVIDER=paddle

# OCR / 模型配置（留空则由最终用户在页面中填写）
FRONT_PADDLE_TOKEN=
FRONT_MINERU_TOKEN=
FRONT_MODEL_API_KEY=
FRONT_MODEL=deepseek-v4-flash
FRONT_BASE_URL=https://api.deepseek.com/v1
