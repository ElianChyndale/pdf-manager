# ============================================================================
# PDF Manager - 环境变量配置
# 复制此文件为 .env 并填入你的密钥:
#   cp .env.example .env
# 然后运行 scripts/start.ps1 (Windows) 或 scripts/start.sh (Linux/Mac)
# ============================================================================

# --- DeepSeek ---
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-v4-flash

# --- Paddle OCR (OpenAI 兼容接口) ---
PADDLE_API_KEY=your-paddle-ocr-api-key
PADDLE_BASE_URL=https://api-m1fbqcjcm3t2tfla.aistudio-app.com/v1
